{
  "name": "BrewLedger",
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/images/(.*)",     "dest": "/public/images/$1" },
    { "src": "/manifest.json",   "dest": "/public/manifest.json" },
    { "src": "/welcome.html",    "dest": "/welcome.html" },
    { "src": "/login.html",      "dest": "/login.html" },
    { "src": "/signup.html",     "dest": "/signup.html" },
    { "src": "/dashboard.html",  "dest": "/dashboard.html" },
    { "src": "/index.html",      "dest": "/dashboard.html" },
    { "src": "/record.html",     "dest": "/record.html" },
    { "src": "/drinks.html",     "dest": "/drinks.html" },
    { "src": "/settings.html",   "dest": "/settings.html" },
    { "src": "/summary.html",    "dest": "/summary.html" },
    { "src": "/(.*)",            "dest": "/welcome.html" }
  ]
}
